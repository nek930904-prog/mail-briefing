# ───────────────────────────────────────────────────────────
#  이 파일은 "양식 견본"입니다. (비밀값을 적지 마세요!)
#  실제로 쓸 때는 이 파일을 복사해서 이름을 .env 로 바꾸고,
#  아래 빈칸에 진짜 값을 채워 넣으세요.
#  .env 파일은 .gitignore 덕분에 깃허브에 올라가지 않습니다.
# ───────────────────────────────────────────────────────────

# ── 네이버 계정 1 ──
NAVER_EMAIL_1=example1@naver.com
NAVER_APP_PASSWORD_1=여기에_앱비밀번호

# ── 네이버 계정 2 ──
NAVER_EMAIL_2=example2@naver.com
NAVER_APP_PASSWORD_2=여기에_앱비밀번호

# ── 노션 ──
# 노션 인테그레이션 토큰 (secret_... 또는 ntn_... 으로 시작)
NOTION_TOKEN=여기에_노션토큰
# 브리핑을 쌓아둘 부모 페이지의 ID
NOTION_PARENT_PAGE_ID=여기에_페이지ID

# ── (선택) 시간대 ──
# GitHub Actions 등에서 한국시간 표기를 맞추기 위한 값. 보통 그대로 두세요.
TIMEZONE=Asia/Seoul
